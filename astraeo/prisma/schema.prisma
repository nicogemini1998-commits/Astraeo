// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("active") // active, paused, archived
  skills    String[] // JSON array of skills
  config    Json?    // Agent configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  missions Mission[]

  @@map("agents")
}

model Mission {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("pending") // pending, in_progress, completed, blocked
  priority  String   @default("medium") // low, medium, high, critical
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  data      Json?    // Mission specific data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("missions")
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  messages  String[] // Serialized messages array
  agentId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_sessions")
}

model Settings {
  id               String   @id @default(cuid())
  companyName      String   @default("Cliender")
  companyContext   String   @default("")
  anthropicApiKey  String?
  theme            String   @default("dark")
  language         String   @default("es")
  updatedAt        DateTime @updatedAt

  @@map("settings")
}

// ─── Multi-agent memory system ────────────────────────────────────────────────

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  key       String
  value     Json
  ttlAt     DateTime? // null = permanent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, key])
  @@index([agentId])
  @@index([ttlAt])
  @@map("agent_memory")
}

model SharedContext {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  writtenBy String   // agentId of last writer
  ttlAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ttlAt])
  @@map("shared_context")
}

model AgentMessage {
  id         String   @id @default(cuid())
  fromAgent  String
  toAgent    String
  channel    String   @default("general") // general, task, memory, alert
  content    Json
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([toAgent, read])
  @@index([fromAgent])
  @@index([createdAt])
  @@map("agent_messages")
}

model TaskLog {
  id          String   @id @default(cuid())
  agentId     String
  taskHash    String   // SHA-256 of task description for dedup
  description String
  status      String   @default("pending") // pending, running, done, failed
  result      Json?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  @@unique([agentId, taskHash])
  @@index([agentId])
  @@index([status])
  @@map("task_log")
}

// Audit log — every security-relevant mutation lands here.
// Never delete rows; archive after retention window via cron if needed.
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "auth.login.success", "agent.update", "settings.write"
  entity    String   // resource type: "session", "agent", "settings", ...
  entityId  String?  // resource id when applicable
  userId    String?  // who did it (session sub)
  ip        String?
  userAgent String?
  meta      Json?    // before/after diff or extra context
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_log")
}
