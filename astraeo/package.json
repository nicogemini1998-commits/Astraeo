    "@prisma/client": "^5.20.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "redis": "^4.7.0",
    "rehype-highlight": "^7.0.2",
