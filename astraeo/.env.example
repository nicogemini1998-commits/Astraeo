# ─── Database ──────────────────────────────────────────────────────────────
# Local dev: postgresql://astraeo:astraeo-dev@localhost:5432/astraeo_db
# Docker: postgresql://astraeo:astraeo-dev@postgres:5432/astraeo_db
DATABASE_URL="postgresql://astraeo:astraeo-dev@localhost:5432/astraeo_db"

# ─── Redis (rate-limit + caching) ──────────────────────────────────────────
# Local dev: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ─── Anthropic API (add from Settings after first login) ──────────────────
ANTHROPIC_API_KEY=""

# ─── Auth (server-side) ────────────────────────────────────────────────────
# Generate bcrypt hash: node scripts/hash-password.mjs 'YourPassword'
AUTH_USER="nicolas"
AUTH_PASS_HASH=""

# ─── JWT signing (generate: openssl rand -base64 48) ─────────────────────
AUTH_SECRET=""

# ─── At-rest encryption key (generate: openssl rand -base64 48) ──────────
APP_SECRET=""

# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3002"
